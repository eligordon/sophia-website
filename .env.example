# TinaCloud — create a project at https://app.tina.io and connect this GitHub repo.
#
# Netlify: Site configuration → Environment variables (set for Production and
# Deploy previews if you want /admin on previews). Use the same names below.
#
# In the TinaCloud dashboard, add your Netlify URL(s) as allowed site URLs so
# /admin can authenticate (exact steps: Tina docs → TinaCloud → site URL).
#
# NEXT_PUBLIC_* is correct: the client ID is embedded in the admin SPA (public).
# TINA_TOKEN is server-only (Netlify build); never commit it or expose in client code.
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Admin preview URL is hardcoded in tina/config.ts (ui.previewUrl) so TinaCloud's
# GitHub indexer and Netlify produce the same schema hash. Change it there when you
# move to a custom domain.

# Optional: local dev with the same TinaCloud project as production (admin talks to cloud).
# Copy the two variables above into a local ".env" file; then "tinacms dev" will use them.

# Offline / no credentials (local GraphQL only — not for Netlify):
#   npm run build
#
# Netlify runs `npm run build:netlify` (tinacms build + --skip-cloud-checks) so
# deploys are not blocked when TinaCloud's GitHub index lags. For a strict check
# locally: `npm run build:cloud` with .env credentials. See netlify.toml footer.
